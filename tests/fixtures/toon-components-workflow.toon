imports:
  components:
    - from: "./toon-components-lib.toon"
      use: [Summarize]

name: component-workflow

input:
  brief: string

steps:
  - id: draft
    run: |
      return { content: `${input.brief} -- draft` };
    output:
      content: string

  - id: synopsis
    kind: component
    use: Summarize
    with:
      text: "{draft.content}"

  - id: finalize
    needs: [synopsis_summary, synopsis_tags]
    run: |
      return {
        summary: synopsis_summary.summary,
        tags: synopsis_tags.tags,
      };
    output:
      summary: string
      tags: string[]
